<Window x:Class="DigitalWPF.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DigitalWPF"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Цифровой двойник пациента" Height="450" Width="800">
    <Grid>
    <StackPanel Margin="10">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock x:Name="UserRoleText" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock x:Name="DoctorFullNameText" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock x:Name="DoctorDepartmentText" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Button x:Name="LogoutButton" Click="LogoutButton_Click" Content="Выход" Width="50" Height="30" VerticalAlignment="Center" Margin="0,0,10,0"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            <TabControl x:Name="menus" TabStripPlacement="Left" Height="600">
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="Главная" />
                    </TabItem.Header>
                    <TabItem.Content>
                        <!-- Система оповещений -->
                        <Border Margin="10"
                        BorderThickness="1"
                        BorderBrush="#CCCCCC"
                        CornerRadius="8"
                        Padding="12"
                        Background="#FFFFFF">

                            <StackPanel>
                                <TextBlock Text="Оповещения"
                                FontSize="16"
                                FontWeight="Bold"
                                Margin="0,0,0,10"/>

                                <!-- Критическое -->
                                <Border Background="#FDECEA" Padding="10" CornerRadius="5" Margin="0,5">
                                    <TextBlock Text="Критическое: резкое ухудшение показателей пациента №16"
                                    Foreground="#B71C1C"/>
                                </Border>

                                <!-- Предупреждение -->
                                <Border Background="#FFF8E1" Padding="10" CornerRadius="5" Margin="0,5">
                                    <TextBlock Text="Предупреждение: превышена нагрузка на врача"
                                    Foreground="#F57F17"/>
                                </Border>

                                <!-- Информационное -->
                                <Border Background="#E3F2FD" Padding="10" CornerRadius="5" Margin="0,5">
                                    <TextBlock Text="Информация: обновлены аналитические данные"
                                    Foreground="#0D47A1"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </TabItem.Content>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="Пациенты" />
                    </TabItem.Header>
                    <TabItem.Content>
                        <!--оборачиваем в стак панель, чтобы поиск сделать в панели-->
                        <StackPanel>
                            <Border BorderBrush="#ccc" BorderThickness="1" Padding="10" CornerRadius="5">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                    <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,10,0" />

                                    <TextBox x:Name="SearchTextBox"
                                         Width="250"
                                         Margin="0,0,10,0"
                                         ToolTip="ФИО, Id пациента или диагноз" />

                                    <Button Content="Найти"
                                    Width="80"
                                    />

                                    <Button Content="Сброс"
                                    Width="80"
                                    Margin="10,0,0,0"
                                    />
                                </StackPanel>
                            </Border>

                            <DataGrid x:Name="PatientsGrid" 
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"

                                  CanUserSortColumns="True"
                                  CanUserResizeColumns="True"
                                  EnableRowVirtualization="True"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="150" CanUserSort="True" />
                                    <DataGridTextColumn Header="Возраст" Binding="{Binding Age}" Width="70" />
                                    <DataGridTextColumn Header="Текущий риск" Binding="{Binding CurrentRisk}" Width="70" />
                                    <DataGridTextColumn Header="Последний замер" Binding="{Binding LastMeasurement}" Width="70" />
                                    <DataGridTextColumn Header="Активные назначения" Binding="{Binding ActivePrescriptionsCount}" Width="70" />
                                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120" />

                                    <DataGridTemplateColumn Header="Действия" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Открыть" Width="50" Margin="2" Tag="{Binding Id}" Click="OpenPatient_Click" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </TabItem.Content>
                </TabItem>

                
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="Мониторинг" />
                    </TabItem.Header>
                </TabItem>
                
                <TabItem Height="20" VerticalAlignment="Top">
                    <TabItem.Header>
                        <TextBlock Text="Назначения" />
                    </TabItem.Header>
                    <TabItem.Content>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="20">
                                <TextBlock Text="Новое назначение" FontSize="18" FontWeight="Bold" Margin="0,0,0,25" />
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Пациент" Margin="0,3,0,25"/>
                                        <TextBlock Text="Препарат" Margin="0 3"/>
                                        <TextBlock Text="Количество" Margin="0 3"/>
                                        <TextBlock Text="Дозировка" Margin="0 3"/>
                                        <TextBlock Text="Частота" Margin="0 3"/>
                                        <TextBlock Text="Сколько применять дней" Margin="0 3"/>
                                        <TextBlock Text="Дата начала" Margin="0 3"/>
                                        <TextBlock Text="Дата конца" Margin="0 3"/>
                                        <TextBlock Text="Инструкция" Margin="0 3"/>
                                        <TextBlock Text="Статус назначения" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBox x:Name="PatientText" Margin="0 1" />
                                        <ComboBox x:Name="PatientIdComboBox" Text="Выбор пациента" Margin="0 1.4" />
                                        <ComboBox x:Name="MedicationIdComboBox" Text="Выбор препарата" Width="150" Margin="0 1.4"/>
                                        <TextBox x:Name="QuantityText" Margin="0 1"/>
                                        <ComboBox x:Name="DoseUnitIdComboBox" Text="Выбор дозировки" Width="150" Margin="0 1.4"/>
                                        <ComboBox x:Name="FrequenceIdComboBox" Text="Выбор частоты" Width="150" Margin="0 1.4"/>
                                        <TextBox x:Name="DurationInDaysText" Margin="0 1"/>
                                        <TextBox x:Name="StartDateText" Margin="0 1"/>
                                        <TextBox x:Name="EndDateText" Margin="0 1"/>
                                        <ComboBox x:Name="InstructionIdComboBox" Text="Выбор инструкции" Width="150" Margin="0 1.4"/>
                                        <ComboBox x:Name="PrescriptionStatusIdComboBox" Text="Выбор статуса назначения" Width="150" Margin="0 1.4"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button x:Name="CreatePrescriptionButton"  Content="Создать" Width="100" Margin="0,10,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem.Content>
                </TabItem>
                
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="Уведомления" />
                    </TabItem.Header>

                    <TabItem.Content>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="20">

                                <!-- Заголовок -->
                                <TextBlock Text="Рабочая нагрузка врача"
                                FontSize="18"
                                FontWeight="Bold"
                                Margin="0,0,0,20"/>

                                <!-- Виджет рабочей нагрузки -->
                                <Border BorderThickness="1"
                                BorderBrush="#DDDDDD"
                                CornerRadius="8"
                                Padding="15"
                                Background="#FAFAFA">

                                    <StackPanel>
                                        <TextBlock Text="Анализ количества приёмов"
                                        FontWeight="SemiBold"
                                        Margin="0,0,0,10"/>

                                        <!-- Псевдо-график (по дням недели) -->
                                        <StackPanel Orientation="Horizontal"
                                        Height="150"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,0,20">

                                            <StackPanel Margin="8" VerticalAlignment="Bottom">
                                                <Border Height="80" Width="30" Background="#4CAF50"/>
                                                <TextBlock Text="Пн" HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Margin="8" VerticalAlignment="Bottom">
                                                <Border Height="120" Width="30" Background="#2196F3"/>
                                                <TextBlock Text="Вт" HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Margin="8" VerticalAlignment="Bottom">
                                                <Border Height="60" Width="30" Background="#FFC107"/>
                                                <TextBlock Text="Ср" HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Margin="8" VerticalAlignment="Bottom">
                                                <Border Height="140" Width="30" Background="#F44336"/>
                                                <TextBlock Text="Чт" HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Margin="8" VerticalAlignment="Bottom">
                                                <Border Height="90" Width="30" Background="#9C27B0"/>
                                                <TextBlock Text="Пт" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Сводная статистика -->
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                            Background="#E3F2FD"
                                            Padding="12"
                                            Margin="5"
                                            CornerRadius="6">
                                                <StackPanel>
                                                    <TextBlock Text="Сегодня" FontWeight="SemiBold"/>
                                                    <TextBlock Text="14 приёмов" FontSize="16"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1"
                                            Background="#E8F5E9"
                                            Padding="12"
                                            Margin="5"
                                            CornerRadius="6">
                                                <StackPanel>
                                                    <TextBlock Text="За неделю" FontWeight="SemiBold"/>
                                                    <TextBlock Text="62 приёма" FontSize="16"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2"
                                            Background="#FFFDE7"
                                            Padding="12"
                                            Margin="5"
                                            CornerRadius="6">
                                                <StackPanel>
                                                    <TextBlock Text="За месяц" FontWeight="SemiBold"/>
                                                    <TextBlock Text="248 приёмов" FontSize="16"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <TextBlock Text="Данные обновляются в режиме реального времени"
                                        FontStyle="Italic"
                                        Foreground="Gray"
                                        Margin="0,15,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Эффективность лечения -->
                                <Border Margin="0,30,0,0"
                                BorderThickness="1"
                                BorderBrush="#DDDDDD"
                                CornerRadius="8"
                                Padding="15"
                                Background="#FAFAFA">

                                    <StackPanel>
                                        <TextBlock Text="Эффективность лечения"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Margin="0,0,0,10"/>

                                        <TextBlock Text="Динамика показателей состояния пациентов"
                                        Foreground="Gray"
                                        Margin="0,0,0,15"/>

                                        <!-- Псевдо-линейный график -->
                                        <StackPanel Orientation="Horizontal"
                                        Height="150"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,0,20">

                                            <StackPanel Margin="8" VerticalAlignment="Bottom">
                                                <Border Height="40" Width="30" Background="#F44336"/>
                                                <TextBlock Text="Янв" HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Margin="8" VerticalAlignment="Bottom">
                                                <Border Height="65" Width="30" Background="#FF9800"/>
                                                <TextBlock Text="Фев" HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Margin="8" VerticalAlignment="Bottom">
                                                <Border Height="85" Width="30" Background="#FFC107"/>
                                                <TextBlock Text="Мар" HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Margin="8" VerticalAlignment="Bottom">
                                                <Border Height="100" Width="30" Background="#8BC34A"/>
                                                <TextBlock Text="Апр" HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Margin="8" VerticalAlignment="Bottom">
                                                <Border Height="90" Width="30" Background="#9C27B0"/>
                                                <TextBlock Text="Май" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock Text="Рост эффективности терапии: +28%"
                                        Foreground="Green"
                                        FontWeight="SemiBold"
                                        Margin="0,15,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Статистика заболеваний -->
                                <Border Margin="0,30,0,0"
                                BorderThickness="1"
                                BorderBrush="#DDDDDD"
                                CornerRadius="8"
                                Padding="15"
                                Background="#FAFAFA">

                                    <StackPanel>
                                        <TextBlock Text="Статистика заболеваний"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Margin="0,0,0,10"/>

                                        <TextBlock Text="Распределение пациентов по нозологиям"
                                        Foreground="Gray"
                                        Margin="0,0,0,15"/>

                                        <!-- Псевдо-диаграмма -->
                                        <StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                                <Rectangle Width="200" Height="18" Fill="#F44336"/>
                                                <TextBlock Text=" Сердечно-сосудистые (40%)" VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                                <Rectangle Width="140" Height="18" Fill="#2196F3"/>
                                                <TextBlock Text=" Эндокринные (28%)" VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                                <Rectangle Width="90" Height="18" Fill="#FFC107"/>
                                                <TextBlock Text=" Дыхательная система (18%)" VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                                <Rectangle Width="60" Height="18" Fill="#9C27B0"/>
                                                <TextBlock Text=" Прочие (14%)" VerticalAlignment="Center"/>
                                            </StackPanel>

                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem.Content>
                </TabItem>

                <TabItem Header="Отчёты">
                    <TabItem.Content>
                        <StackPanel Margin="20">
                            
                            <TextBlock Text="Экспорт данных" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                            
                            <!-- Отчёт 1: Пациенты -->
                            <Border BorderBrush="#ccc" BorderThickness="1" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Отчёт по пациентам" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock Text="Список всех пациентов с текущим риском" Foreground="Gray" Margin="0,0,0,10"/>
                                    <Button x:Name="ExportPatientsBtn" Content="Экспорт в CSV" Click="ExportPatientsToCsv_Click" Width="150" Height="35"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Отчёт 2: Назначения -->
                            <Border BorderBrush="#ccc" BorderThickness="1" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Отчёт по назначениям" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock Text="Выполненные и невыполненные назначения" Foreground="Gray" Margin="0,0,0,10"/>
                                    <Button x:Name="ExportPrescriptionsBtn" Content="Экспорт в CSV" Click="ExportPrescriptionsToCsv_Click" Width="150" Height="35"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Отчёт 3: События за период -->
                            <Border BorderBrush="#ccc" BorderThickness="1" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Отчёт по событиям" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock Text="События (замеры, назначения, уведомления)" Foreground="Gray" Margin="0,0,0,10"/>
                                    
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <DatePicker x:Name="StartDatePicker" Width="120" Margin="0,0,10,0"/>
                                        <TextBlock Text="—" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <DatePicker x:Name="EndDatePicker" Width="120" Margin="0,0,10,0"/>
                                    </StackPanel>
                                    
                                    <Button x:Name="ExportEventsBtn" Content="Экспорт в CSV" Click="ExportEventsToCsv_Click" Width="150" Height="35"/>
                                </StackPanel>
                            </Border>
                            
                        </StackPanel>
                    </TabItem.Content>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="Аудит" />
                    </TabItem.Header>
                </TabItem>
            </TabControl>
        </StackPanel>
    </StackPanel>
</Grid>
</Window>

<Window x:Class="DigitalWPF.PatientMonitoringWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DigitalWPF"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Цифровой двойник пациента" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Информация о пациенте -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="PatientNameText" FontSize="18" FontWeight="Bold"/>
            <TextBlock x:Name="PatientInfoText" Foreground="Gray"/>
        </StackPanel>
        
        <!-- Вкладки -->
        <TabControl Grid.Row="1">
            <TabItem Header="Общее">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <!-- Хронические заболевания -->
                        <TextBlock Text="Хронические заболевания" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ListBox x:Name="ChronicDiseasesList" Height="100" Margin="0,0,0,15"/>
                        
                        <!-- Текущий риск -->
                        <TextBlock Text="Текущий интегральный риск" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Border x:Name="RiskBorder" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                            <TextBlock x:Name="RiskText" FontSize="24" FontWeight="Bold" TextAlignment="Center"/>
                        </Border>
                        
                        <!-- Последний замер -->
                        <TextBlock Text="Последний замер" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10">
                            <StackPanel>
                                <TextBlock x:Name="LastMeasurementDate"/>
                                <TextBlock x:Name="LastMeasurementValues"/>
                                <TextBlock x:Name="LastMeasurementComplaints"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Кнопка добавить замер -->
                        <Button x:Name="AddMeasurementBtn" Content="Добавить замер вручную" 
                                Click="AddMeasurement_Click" 
                                Margin="0,15,0,0" Padding="10"/>
                        
                        <!-- Рекомендация врача -->
                        <TextBlock Text="Рекомендация врача" FontWeight="Bold" Margin="0,15,0,5"/>
                        <ComboBox x:Name="RecommendationCombo" Margin="0,0,0,10">
                            <ComboBoxItem Content="Оставить наблюдение"/>
                            <ComboBoxItem Content="Назначить очный приём"/>
                            <ComboBoxItem Content="Госпитализация"/>
                        </ComboBox>
                        <Button Content="Сохранить рекомендацию" Click="SaveRecommendation_Click" Width="150"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <TabItem Header="Динамика">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Выбор периода -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="PeriodCombo" Width="100" SelectionChanged="PeriodCombo_SelectionChanged">
                            <ComboBoxItem Content="7 дней" IsSelected="True"/>
                            <ComboBoxItem Content="14 дней"/>
                            <ComboBoxItem Content="30 дней"/>
                        </ComboBox>
                    </StackPanel>
                    
                    <!-- График риска -->
                    <TextBlock Grid.Row="1" Text="График изменения риска" FontWeight="Bold"/>
                    <ListBox x:Name="RiskChart" Grid.Row="1" Margin="0,20,0,20" Height="150"/>
                    
                    <!-- Выбор параметра -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Параметр:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="ParameterCombo" Width="120" SelectionChanged="ParameterCombo_SelectionChanged">
                            <ComboBoxItem Content="Давление" IsSelected="True"/>
                            <ComboBoxItem Content="Пульс"/>
                        </ComboBox>
                        <TextBlock x:Name="TrendText" Margin="20,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- График давления/пульса -->
                    <TextBlock Grid.Row="3" Text="График измерений" FontWeight="Bold"/>
                    <ListBox x:Name="ParameterChart" Grid.Row="3" Margin="0,20,0,0" Height="150"/>
                </Grid>
            </TabItem>
            
            <TabItem Header="Назначения">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Активные назначения" FontWeight="Bold"/>
                    <DataGrid x:Name="ActivePrescriptionsGrid" Grid.Row="1" Margin="0,10,0,10"
                              AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Лекарство/Действие" Binding="{Binding MedicationName}" Width="150"/>
                            <DataGridTextColumn Header="Дозировка" Binding="{Binding Dosage}" Width="80"/>
                            <DataGridTextColumn Header="Периодичность" Binding="{Binding Frequency}" Width="100"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="80"/>
                            <DataGridTemplateColumn Header="Выполнено" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsCompleted}" IsEnabled="False"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <StackPanel Grid.Row="2">
                        <Button Content="Создать назначение" Click="CreatePrescription_Click" Width="150" Margin="0,0,0,10"/>
                        <TextBlock Text="Завершённые назначения" FontWeight="Bold"/>
                        <DataGrid x:Name="CompletedPrescriptionsGrid" Height="120" Margin="0,5,0,0"
                                  AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Лекарство/Действие" Binding="{Binding MedicationName}" Width="150"/>
                                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <TabItem Header="Замеры">
                <DataGrid x:Name="MeasurementsGrid" Margin="10"
                          AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Binding="{Binding MeasuredAt, StringFormat='dd.MM.yyyy HH:mm'}" Width="120"/>
                        <DataGridTextColumn Header="Давление" Binding="{Binding Pressure}" Width="100"/>
                        <DataGridTextColumn Header="Пульс" Binding="{Binding HeartRate}" Width="60"/>
                        <DataGridTextColumn Header="Жалобы" Binding="{Binding Complaints}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            
            <TabItem Header="Уведомления">
                <DataGrid x:Name="NotificationsGrid" Margin="10"
                          AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" Width="120"/>
                        <DataGridTextColumn Header="Тип" Binding="{Binding NotificationType}" Width="100"/>
                        <DataGridTextColumn Header="Сообщение" Binding="{Binding Message}" Width="300"/>
                        <DataGridTemplateColumn Header="Прочитано" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsRead}" IsEnabled="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            
            <TabItem Header="Аудит">
                <DataGrid x:Name="AuditGrid" Margin="10"
                          AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" Width="120"/>
                        <DataGridTextColumn Header="Действие" Binding="{Binding ActionType}" Width="150"/>
                        <DataGridTextColumn Header="Новые данные" Binding="{Binding NewValue}" Width="300"/>
                        <DataGridTextColumn Header="Кто" Binding="{Binding UserName}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
